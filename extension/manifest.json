{
  "manifest_version": 3,
  "name": "OpenClaw Browser Host",
  "description": "Browser-side OpenClaw host for notifications, page context, and browser-scoped capabilities.",
  "version": "0.1.0",
  "minimum_chrome_version": "116",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "OpenClaw Browser Host",
    "default_popup": "src/popup.html"
  },
  "options_page": "src/options.html",
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "permissions": [
    "activeTab",
    "alarms",
    "downloads",
    "notifications",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": []
}
